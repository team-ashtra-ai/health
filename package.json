{
  "name": "franciele-sofiati-website",
  "version": "1.0.0",
  "private": true,
  "description": "Build, validation and performance tooling for the Franciele Sofiati website.",
  "type": "module",
  "scripts": {
    "serve": "node scripts/build/serve-production.mjs .",
    "perf:baseline": "node scripts/performance/performance-audit.mjs --source . --label baseline",
    "perf:mobile": "node scripts/performance/performance-audit.mjs --source . --label final --profile mobile",
    "perf:desktop": "node scripts/performance/performance-audit.mjs --source . --label final --profile desktop",
    "perf:all": "node scripts/performance/performance-audit.mjs --source . --label final",
    "perf:ci": "lhci autorun --config=config/performance/lighthouserc.mobile.cjs && lhci autorun --config=config/performance/lighthouserc.desktop.cjs",
    "perf:budget": "node scripts/performance/check-performance-budgets.mjs",
    "perf:psi": "node scripts/performance/psi-audit.mjs",
    "perf:images": "node scripts/performance/image-audit.mjs",
    "perf:visual": "node scripts/performance/visual-regression.mjs",
    "check:assets": "python3 scripts/check-local-assets.py",
    "check:pt": "python3 scripts/check-portuguese-site.py --strict-warnings",
    "check:seo": "python3 scripts/check-seo-files.py && python3 scripts/check-seo-implementation.py",
    "check:analytics": "python3 scripts/check-analytics-implementation.py",
    "seo:refresh": "python3 scripts/weekly-seo-maintenance.py",
    "maintain:performance": "python3 scripts/weekly-performance-maintenance.py",
    "validate": "npm run check:assets && npm run check:pt && npm run check:seo && npm run check:analytics",
    "release:check": "npm run validate"
  },
  "engines": {
    "node": ">=22.19"
  },
  "devDependencies": {
    "@lhci/cli": "0.15.1",
    "esbuild": "0.28.1",
    "html-minifier-terser": "7.2.0",
    "lighthouse": "13.4.0",
    "playwright-core": "1.61.1",
    "sharp": "0.35.3"
  }
}
